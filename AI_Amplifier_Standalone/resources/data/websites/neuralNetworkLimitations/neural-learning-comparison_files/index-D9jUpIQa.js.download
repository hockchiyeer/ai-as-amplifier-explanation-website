for epoch in range(num_epochs):
    for batch in data_loader:
        # Process EVERY sample in dataset
        inputs, targets = batch
        outputs = model(inputs)
        loss = criterion(outputs, targets)
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()`},{id:2,title:"Knowledge Acquisition",shortDesc:"How new information is gathered",humanDesc:"Humans can quickly browse content, extract key information, and focus only on what's relevant. We naturally filter out noise and prioritize important details.",machineDesc:"Neural networks require carefully curated, engineered data. They process all information with equal weight initially, requiring extensive training to learn which features are important.",codeSnippet:`# Data Engineering Process
def prepare_training_data(raw_data):
    # Extensive preprocessing required
    cleaned_data = clean_data(raw_data)
    engineered_features = extract_features(cleaned_data)
    normalized_data = normalize(engineered_features)
    return DataLoader(normalized_data, batch_size=32)`},{id:3,title:"Abstraction Ability",shortDesc:"How concepts are generalized",humanDesc:"Humans excel at generalizing from minimal examples. We can see one or two instances of a concept and immediately apply it to new situations.",machineDesc:"Neural networks need extensive examples to form generalizations. They require many variations of similar inputs to develop robust representations.",codeSnippet:`# Data Augmentation to Help Generalization
def augment_training_data(images, labels):
    augmented_images = []
    augmented_labels = []
    
    for image, label in zip(images, labels):
        # Create MANY variations of same example
        augmented_images.append(image)
        augmented_images.append(flip(image))
        augmented_images.append(rotate(image))
        augmented_images.append(add_noise(image))
        # ...and so on
        
        augmented_labels.extend([label] * 4)
        
    return augmented_images, augmented_labels`},{id:4,title:"Resource Consumption",shortDesc:"Energy and time requirements",humanDesc:"Human learning is relatively efficient in terms of energy and time. We can learn significant concepts with minimal exposure and retain them for long periods.",machineDesc:"Neural network training is time-consuming, energy-intensive, and storage-heavy. Training large models can take weeks and consume enormous computational resources.",codeSnippet:`# Resource Requirements
"""
GPT-3 Training Stats:
- 175 billion parameters
- Trained on 45TB of text data
- Training cost: ~$4.6 million
- Energy consumption: ~1,287 MWh
- Carbon footprint: ~552 tons of CO2
- Training time: weeks on supercomputer clusters
"""

# Even smaller models are resource-intensive
model = Transformer(
    layers=12,
    hidden_size=768,
    num_heads=12
)  # Still requires significant GPU time`}];return S.jsx("section",{className:"detailed-explanation-section",ref:i,children:S.jsxs(Te.div,{className:"section-container",variants:l,initial:"hidden",animate:o?"visible":"hidden",children:[S.jsx(Te.h2,{variants:f,className:"section-title",children:"Understanding the Differences in Detail"}),S.jsx(Te.p,{variants:f,className:"section-description",children:"Explore the key differences between human learning and neural network learning through these interactive cards. Click on each card to learn more."}),S.jsx(Te.div,{variants:f,className:"explanation-cards",children:d.map(p=>S.jsxs(Te.div,{className:`explanation-card ${t===p.id?"expanded":""}`,variants:c,initial:"collapsed",animate:t===p.id?"expanded":"collapsed",onClick:()=>r(t===p.id?null:p.id),children:[S.jsxs("div",{className:"card-header",children:[S.jsx("h3",{children:p.title}),S.jsx("p",{className:"card-short-desc",children:p.shortDesc}),S.jsx("div",{className:"expand-icon",children:t===p.id?"−":"+"})]}),t===p.id&&S.jsxs("div",{className:"card-expanded-content",children:[S.jsxs("div",{className:"comparison-columns",children:[S.jsxs("div",{className:"human-column",children:[S.jsx("h4",{children:"Human Learning"}),S.jsx("p",{children:p.humanDesc})]}),S.jsxs("div",{className:"machine-column",children:[S.jsx("h4",{children:"Neural Network"}),S.jsx("p",{children:p.machineDesc})]})]}),S.jsxs("div",{className:"code-snippet",children:[S.jsx("h4",{children:"Technical Implementation"}),S.jsx("pre",{children:S.jsx("code",{children:p.codeSnippet})})]})]})]},p.id))})]})})};function ko(t,r){return t==null||r==null?NaN:t<r?-1:t>r?1:t>=r?0:NaN}function Tk(t,r){return t==null||r==null?NaN:r<t?-1:r>t?1:r>=t?0:NaN}function Xg(t){let r,i,o;t.length!==2?(r=ko,i=(d,p)=>ko(t(d),p),o=(d,p)=>t(d)-p):(r=t===ko||t===Tk?t:_k,i=t,o=t);function l(d,p,m=0,g=d.length){if(m<g){if(r(p,p)!==0)return g;do{const v=m+g>>>1;i(d[v],p)<0?m=v+1:g=v}while(m<g)}return m}function f(d,p,m=0,g=d.length){if(m<g){